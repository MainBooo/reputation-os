DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reputation_os
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
DEMO_MODE=true

# ============================================
# Telegram Scout — dedicated MTProto account (separate from the Telegraf
# notifications bot's TELEGRAM_BOT_TOKEN). See TELEGRAM_MONITORING.md.
# ============================================
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=
TELEGRAM_SCOUT_ENABLED=false

# DISCOVERY query/message budgets (per company, per run)
TELEGRAM_SCOUT_MAX_QUERIES_PER_COMPANY=6
TELEGRAM_SCOUT_MAX_STRONG_QUERIES=3
TELEGRAM_SCOUT_MAX_MEDIUM_QUERIES=2
TELEGRAM_SCOUT_MAX_WEAK_QUERIES=1
TELEGRAM_SCOUT_MAX_PAGES_PER_QUERY=3
TELEGRAM_SCOUT_MAX_MESSAGES_PER_RUN=300
TELEGRAM_SCOUT_MAX_NEW_SOURCES_PER_RUN=15
TELEGRAM_SCOUT_MAX_RUNTIME_MS=180000
TELEGRAM_SCOUT_DISCOVERY_INTERVAL_HOURS=24
TELEGRAM_SCOUT_NOISE_THRESHOLD=0.9
# channels.searchPosts hashtag mode only (free) — paid full-text mode is never used
TELEGRAM_SCOUT_ENABLE_HASHTAG_POST_SEARCH=false

# WATCHLIST incremental reads
TELEGRAM_WATCHLIST_MAX_MESSAGES_PER_CHANNEL=50
TELEGRAM_WATCHLIST_DISPATCHER_INTERVAL_MIN=5

# Shared search/pagination behavior (global search, per-peer deep search)
TELEGRAM_SEARCH_RESULTS_LIMIT=8
TELEGRAM_SEARCH_DELAY_MS=1500
TELEGRAM_SEARCH_RETRY_ATTEMPTS=3

# Redis MTProto lock — self-requeue policy for DISCOVERY/ENTITY_SEARCH/SOURCE_CHECK
TELEGRAM_LOCK_RETRY_DELAY_MS=15000
TELEGRAM_LOCK_MAX_SELF_REQUEUES=5
