DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reputation_os
JWT_SECRET=supersecret
REDIS_URL=redis://localhost:6379
PORT=3000
DEMO_MODE=true

# Billing / YooKassa
BILLING_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://yourdomain.ru/billing/payment-result

# Yandex ID OAuth (https://oauth.yandex.ru/client/new)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://yourdomain.ru/api/auth/yandex/callback

# Rate limiting (Redis-backed, apps/api/src/common/rate-limit). Все опциональны,
# значения ниже — дефолты в коде, если ENV не задан.
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_TTL_MS=900000
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_TTL_MS=3600000
RATE_LIMIT_CREATE_COMPANY_MAX=10
RATE_LIMIT_CREATE_COMPANY_TTL_MS=3600000
RATE_LIMIT_DISCOVER_SOURCES_MAX=5
RATE_LIMIT_DISCOVER_SOURCES_TTL_MS=3600000
RATE_LIMIT_BILLING_CHECKOUT_MAX=10
RATE_LIMIT_BILLING_CHECKOUT_TTL_MS=900000
