          </span>
          <span className="whitespace-nowrap text-sm font-semibold tracking-[0.22em] text-white">
            REPUTATION OS
          </span>
        </Link>

        <nav className="hidden flex-1 items-center justify-center gap-10 text-sm font-medium text-slate-300 lg:flex">
