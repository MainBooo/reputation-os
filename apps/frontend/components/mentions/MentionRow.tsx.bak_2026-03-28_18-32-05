import Badge from '../ui/Badge'

async function updateStatus(id: string, status: string) {
  await fetch(`${process.env.NEXT_PUBLIC_API_URL}/mentions/${id}/status`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  })
  location.reload()
}

export default function MentionRow({
  mention
}: {
  mention: any
}) {
  return (
    <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition rounded-2xl border border-line bg-panel p-4">
      <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition flex flex-wrap items-start justify-between gap-3">
        <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition min-w-0 flex-1">
          <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition flex flex-wrap items-center gap-2">
            <Badge tone={mention.platform}>{mention.platform}</Badge>
            <Badge tone=<span className={
  mention.sentiment === 'NEGATIVE'
    ? 'text-red-400'
    : mention.sentiment === 'POSITIVE'
    ? 'text-green-400'
    : 'text-yellow-400'
}>
  {mention.sentiment}
</span>><span className={
  mention.sentiment === 'NEGATIVE'
    ? 'text-red-400'
    : mention.sentiment === 'POSITIVE'
    ? 'text-green-400'
    : 'text-yellow-400'
}>
  {mention.sentiment}
</span></Badge>
            <Badge tone={mention.status}>{mention.status}</Badge>
            {mention.type ? <Badge>{mention.type}</Badge> : null}
          </div>
          <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition mt-3 text-sm leading-6 text-brand">{mention.content}</div>
          <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition mt-3 text-xs text-muted">
            {mention.author || 'Unknown'} · {new Date(mention.publishedAt).toLocaleString()}
          </div>
        </div>
        <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition text-right">
          {mention.ratingValue ? <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition text-lg font-semibold text-brand">{mention.ratingValue}</div> : null}
          {mention.url ? (
            <a href={mention.url} target="_blank" className="cursor-pointer hover:bg-zinc-800 transition mt-2 inline-block text-xs text-muted hover:text-brand">
              Original source
            </a>
          ) : null}
        </div>
      </div>
    
    <div onClick={onClick} className="cursor-pointer hover:bg-zinc-800 transition flex gap-2 mt-2">
      <button
        onClick={() => updateStatus(mention.id, 'REVIEWED')}
        className="cursor-pointer hover:bg-zinc-800 transition text-xs px-2 py-1 bg-blue-500 text-white rounded"
      >
        Review
      </button>

      <button
        onClick={() => updateStatus(mention.id, 'ARCHIVED')}
        className="cursor-pointer hover:bg-zinc-800 transition text-xs px-2 py-1 bg-gray-500 text-white rounded"
      >
        Archive
      </button>
    </div>
  </div>
  )
}
