generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  YANDEX
  GOOGLE
  TWOGIS
  WEB
  CUSTOM
}

enum SourceType {
  REVIEW_FEED
  RATING_FEED
  WEB_MENTION_FEED
  CUSTOM_FEED
}

enum MentionType {
  REVIEW
  ARTICLE
  WEB_MENTION
  SOCIAL_MENTION
  COMMENT
}

enum MentionStatus {
  NEW
  REVIEWED
  HIDDEN
  ARCHIVED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
  UNKNOWN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum SystemRole {
  USER
  SUPER_ADMIN
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WEBHOOK
  IN_APP
}

enum NotificationType {
  NEW_NEGATIVE_MENTION
  NEW_REVIEW
  RATING_DROP
  DAILY_DIGEST
  AI_REPLY_READY
  WORKSPACE_INVITE
  SUBSCRIPTION_REMINDER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  isActive     Boolean    @default(true)
  systemRole   SystemRole @default(USER)
  lastLoginAt  DateTime?
  welcomeSeen  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  telegramChatId    BigInt?   @unique
  telegramLinkedAt  DateTime?
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  deletedById  String?

  workspaceMembers     WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[]
  notifications        Notification[]
  aiReplyDrafts        AIReplyDraft[]        @relation("AIReplyDraftCreatedBy")
  jobLogsTriggered     JobLog[]              @relation("JobLogTriggeredBy")
  webPushSubscriptions WebPushSubscription[]
  telegramLinkToken    TelegramLinkToken?
  telegramDeliveries   TelegramMentionDelivery[]
  auditLogsAuthored    AuditLog[]            @relation("AuditLogActor")
  auditLogsTargeted    AuditLog[]            @relation("AuditLogTarget")
  subscriptionsManaged Subscription[]        @relation("SubscriptionManagedBy")

  chatThreadsCreated ChatThread[]     @relation("ChatThreadCreatedBy")
  chatMessages       ChatMessage[]
  chatReadStates     ChatReadState[]
  chatMentions       ChatMention[]
  chatParticipants   ChatParticipant[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  deletedById String?
  members              WorkspaceMember[]
  invites              WorkspaceInvite[]
  companies            Company[]
  sources              Source[]
  notificationRules    NotificationRule[]
  subscription         Subscription?
  payments             Payment[]
  featureOverrides     FeatureOverride[]
  webPushSubscriptions WebPushSubscription[]
  auditLogs            AuditLog[]            @relation("AuditLogWorkspace")
  chatThreads          ChatThread[]

  @@index([slug])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  token       String        @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  declinedAt  DateTime?
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

enum ResponsePreset {
  FORMAL
  FRIENDLY
  CONCISE
}

model Company {
  id                     String    @id @default(cuid())
  workspaceId            String
  name                   String
  normalizedName         String
  website                String?
  normalizedWebsite      String?
  city                   String?
  normalizedCity         String?
  industry               String?
  description            String?
  logoUrl                String?
  isActive               Boolean   @default(true)
  responsePreset         ResponsePreset @default(FORMAL)
  initialSyncCompletedAt DateTime?
  lastSyncedAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aliases           CompanyAlias[]
  sourceTargets     CompanySourceTarget[]
  mentions          Mention[]
  ratingSnapshots   RatingSnapshot[]
  watchedPages      WatchedPage[]
  watchedPageItems  WatchedPageItem[]
  aiReplyDrafts     AIReplyDraft[]
  notificationRules NotificationRule[]
  chatThreads       ChatThread[]          @relation("CompanyChatThreads")
  subscription      Subscription?         @relation(fields: [subscriptionId], references: [id])
  payments          Payment[]
  featureOverrides  FeatureOverride[]
  jobLogs           JobLog[]
  subscriptionId    String?

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([normalizedName])
  @@index([normalizedWebsite])
  @@index([normalizedCity])
}

model CompanyAlias {
  id              String   @id @default(cuid())
  companyId       String
  value           String
  normalizedValue String
  priority        Int      @default(100)
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, normalizedValue])
  @@index([companyId, priority])
  @@index([normalizedValue])
}

model Source {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  platform    Platform
  type        SourceType
  baseUrl     String?
  isEnabled   Boolean    @default(true)
  config      Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyTargets    CompanySourceTarget[]
  mentions          Mention[]
  ratingSnapshots   RatingSnapshot[]
  jobLogs           JobLog[]
  notificationRules NotificationRule[]

  @@index([workspaceId])
  @@index([workspaceId, platform, type])
  @@index([platform, type])
}

model CompanySourceTarget {
  id                  String    @id @default(cuid())
  companyId           String
  sourceId            String
  externalPlaceId     String?
  externalUrl         String?
  displayName         String?
  isActive            Boolean   @default(true)
  syncReviewsEnabled  Boolean   @default(true)
  syncRatingsEnabled  Boolean   @default(true)
  syncMentionsEnabled Boolean   @default(true)
  config              Json?
  lastSyncedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source          Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  mentions        Mention[]
  ratingSnapshots RatingSnapshot[]
  watchedPages    WatchedPage[]

  @@unique([companyId, sourceId, externalPlaceId])
  @@index([companyId])
  @@index([sourceId])
  @@index([companyId, isActive])
  @@index([companyId, sourceId])
}

model Mention {
  id                    String      @id @default(cuid())
  companyId             String
  platform              Platform
  type                  MentionType
  sourceId              String
  companySourceTargetId String?

  externalMentionId String?
  url               String?
  title             String?
  content           String
  normalizedContent String
  author            String?
  authorExternalId  String?
  publishedAt       DateTime
  discoveredAt      DateTime      @default(now())
  ratingValue       Decimal?      @db.Decimal(3, 1)
  sentiment         Sentiment     @default(UNKNOWN)
  status            MentionStatus @default(NEW)

  isRelevant     Boolean  @default(true)
  relevanceScore Decimal? @db.Decimal(5, 2)
  hash           String
  duplicateOfId  String?

  rawPayload Json?
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source              Source               @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  companySourceTarget CompanySourceTarget? @relation(fields: [companySourceTargetId], references: [id], onDelete: SetNull)

  duplicateOf Mention?  @relation("MentionDuplicateLink", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates  Mention[] @relation("MentionDuplicateLink")

  aiReplyDrafts AIReplyDraft[]
  telegramDeliveries TelegramMentionDelivery[]
  chatThreads    ChatThread[]    @relation("MentionChatThreads")

  @@unique([companyId, platform, externalMentionId], map: "mention_company_platform_external_unique")
  @@unique([companyId, hash], map: "mention_company_hash_unique")
  @@index([companyId])
  @@index([companyId, publishedAt(sort: Desc)])
  @@index([companyId, platform, publishedAt(sort: Desc)])
  @@index([companyId, type, publishedAt(sort: Desc)])
  @@index([companyId, sentiment, publishedAt(sort: Desc)])
  @@index([sourceId, publishedAt(sort: Desc)])
  @@index([companySourceTargetId])
  @@index([externalMentionId])
  @@index([hash])
  @@index([duplicateOfId])
}

model RatingSnapshot {
  id                    String   @id @default(cuid())
  companyId             String
  sourceId              String
  companySourceTargetId String?
  platform              Platform
  ratingValue           Decimal  @db.Decimal(3, 1)
  reviewsCount          Int?
  capturedAt            DateTime
  rawPayload            Json?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source              Source               @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  companySourceTarget CompanySourceTarget? @relation(fields: [companySourceTargetId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, capturedAt(sort: Desc)])
  @@index([companyId, platform, capturedAt(sort: Desc)])
  @@index([sourceId, capturedAt(sort: Desc)])
  @@index([companySourceTargetId])
}

model AIReplyDraft {
  id              String   @id @default(cuid())
  companyId       String
  mentionId       String
  createdByUserId String?
  languageCode    String   @default("ru")
  tone            String?
  promptVersion   String?
  draftText       String
  status          String   @default("READY")
  modelName       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mention       Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("AIReplyDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([mentionId])
  @@index([createdByUserId])
  @@index([companyId, createdAt(sort: Desc)])
}

model NotificationRule {
  id          String              @id @default(cuid())
  workspaceId String
  companyId   String?
  name        String
  isActive    Boolean             @default(true)
  channel     NotificationChannel
  type        NotificationType

  platformFilter    Platform?
  mentionTypeFilter MentionType?
  sentimentFilter   Sentiment?
  sourceIdFilter    String?

  minRatingValue Decimal? @db.Decimal(3, 1)
  maxRatingValue Decimal? @db.Decimal(3, 1)
  config         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceFilter Source?   @relation(fields: [sourceIdFilter], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([companyId])
  @@index([sourceIdFilter])
  @@index([workspaceId, isActive])
  @@index([workspaceId, type, channel])
}

model WebPushSubscription {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String
  endpoint    String  @unique
  p256dh      String
  auth        String
  userAgent   String?
  isActive    Boolean @default(true)

  alertSentiments    String[]  @default(["NEGATIVE"])
  lastAlertCheckedAt DateTime?
  lastUsedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, isActive])
  @@index([userId, isActive])
  @@index([workspaceId, isActive, lastAlertCheckedAt])
}

model JobLog {
  id                String    @id @default(cuid())
  companyId         String?
  sourceId          String?
  triggeredByUserId String?
  queueName         String
  jobName           String
  jobStatus         JobStatus
  startedAt         DateTime?
  finishedAt        DateTime?
  itemsDiscovered   Int?
  itemsCreated      Int?
  itemsUpdated      Int?
  itemsDeduped      Int?
  errorMessage      String?
  payload           Json?
  result            Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  source          Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  triggeredByUser User?    @relation("JobLogTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([sourceId])
  @@index([triggeredByUserId])
  @@index([jobStatus])
  @@index([queueName, jobName])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// BILLING
// ============================================

enum PlanCode {
  FREE
  START
  STARTER
  PRO
  BUSINESS
  AGENCY
  ENTERPRISE
  CUSTOM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  MANUAL
  PAUSED
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
}

enum BillingProvider {
  MOCK
  YOOKASSA
}

model Plan {
  id           String   @id @default(cuid())
  code         PlanCode @unique
  name         String
  priceMonthly Int      // рубли в месяц
  priceYearly  Int?     // рубли в год (скидка ~20%)
  isActive     Boolean  @default(true)
  limits       Json     // { maxCompanies, maxAiRepliesPerMonth, platforms[], telegramNotifications, advancedAnalytics }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                String             @id @default(cuid())
  workspaceId       String             @unique
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean            @default(false)
  provider          BillingProvider    @default(MOCK)
  trialEndsAt       DateTime?
  adminNote         String?
  updatedByAdminId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan           Plan      @relation(fields: [planId], references: [id])
  updatedByAdmin User?     @relation("SubscriptionManagedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  Company        Company[]
  reminderLogs   SubscriptionReminderLog[]

  @@index([status, currentPeriodEnd])
  @@index([status, trialEndsAt])
}

model SubscriptionReminderLog {
  id             String   @id @default(cuid())
  subscriptionId String
  reminderType   String   // TRIAL_ENDING | SUBSCRIPTION_ENDING
  daysBefore     Int      // 3, 1, 0
  periodEndDate  DateTime // trialEndsAt or currentPeriodEnd (для идемпотентности)
  sentAt         DateTime @default(now())
  channels       String[] // ['PUSH', 'TELEGRAM', 'IN_APP']

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, reminderType, daysBefore, periodEndDate])
  @@index([sentAt(sort: Desc)])
}

model Payment {
  id                String          @id @default(cuid())
  workspaceId       String
  userId            String?
  planCode          PlanCode
  amount            Int             // рубли
  currency          String          @default("RUB")
  billingPeriod     String          @default("monthly") // 'monthly' | 'yearly'
  status            PaymentStatus   @default(PENDING)
  provider          BillingProvider @default(MOCK)
  providerPaymentId String?         @unique
  confirmationUrl   String?
  rawPayload        Json?
  paidAt            DateTime?
  canceledAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@index([workspaceId])
  @@index([status])
}

model FeatureOverride {
  id          String   @id @default(cuid())
  workspaceId String
  featureKey  String // 'telegramNotifications' | 'advancedAnalytics' | 'maxCompanies' | 'maxAiRepliesPerMonth' | 'platforms'
  value       Json // true/false или число/массив для лимитов
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@unique([workspaceId, featureKey])
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TelegramDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model TelegramMentionDelivery {
  id        String                 @id @default(cuid())
  mentionId String
  userId    String
  chatId    BigInt
  status    TelegramDeliveryStatus @default(PENDING)
  attempts  Int                    @default(0)
  lastError String?
  sentAt    DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  mention Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mentionId, userId], map: "telegram_delivery_mention_user_unique")
  @@index([mentionId])
  @@index([userId])
  @@index([status])
}

model WatchedPage {
  id                String    @id @default(cuid())
  companyId         String
  sourceTargetId    String?
  url               String
  domain            String
  pageType          String    @default("UNKNOWN")
  pageTypeCheckedAt DateTime?
  enabled           Boolean   @default(true)
  lastCheckedAt     DateTime?
  lastChangedAt     DateTime?
  lastError         String?
  contentHash       String?
  checkIntervalMin  Int       @default(1440)
  nextCheckAt       DateTime?
  etag              String?
  lastModifiedHeader String?
  consecutiveErrors Int       @default(0)
  disabledReason    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceTarget CompanySourceTarget? @relation(fields: [sourceTargetId], references: [id], onDelete: SetNull)

  items        WatchedPageItem[]

  @@unique([companyId, url])
  @@index([companyId])
  @@index([enabled, lastCheckedAt])
  @@index([enabled, nextCheckAt])
}

model WatchedPageItem {
  id            String   @id @default(cuid())
  watchedPageId String
  companyId     String
  itemHash      String
  itemType      String
  title         String?
  content       String?
  author        String?
  ratingValue   Int?
  publishedAt   DateTime?
  url           String?
  createdAt     DateTime @default(now())

  watchedPage WatchedPage @relation(fields: [watchedPageId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([watchedPageId, itemHash])
  @@index([companyId])
}

// ============================================
// CHAT
// ============================================

enum ChatThreadType {
  WORKSPACE
  COMPANY
  MENTION
  DIRECT
}

enum ChatMessageType {
  TEXT
  SYSTEM
}

model ChatThread {
  id            String         @id @default(cuid())
  workspaceId   String?
  type          ChatThreadType
  companyId     String?
  mentionId     String?
  title         String?
  isArchived    Boolean        @default(false)
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastMessageAt DateTime?

  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company      Company?         @relation("CompanyChatThreads", fields: [companyId], references: [id], onDelete: Cascade)
  mention      Mention?         @relation("MentionChatThreads", fields: [mentionId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("ChatThreadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages     ChatMessage[]
  readStates   ChatReadState[]
  participants ChatParticipant[]

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
  @@index([companyId])
  @@index([mentionId])
  @@index([type])
}

model ChatParticipant {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model ChatMessage {
  id          String          @id @default(cuid())
  threadId    String
  workspaceId String?
  authorId    String

  body      String
  type      ChatMessageType @default(TEXT)
  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread   ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author   User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mentions ChatMention[]

  @@index([threadId, createdAt(sort: Desc)])
  @@index([workspaceId])
  @@index([authorId])
  @@index([deletedAt])
}

model ChatReadState {
  id                String   @id @default(cuid())
  threadId          String
  userId            String
  workspaceId       String?
  lastReadAt        DateTime @default(now())
  lastReadMessageId String?

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model ChatMention {
  id              String   @id @default(cuid())
  messageId       String
  mentionedUserId String
  workspaceId     String
  createdAt       DateTime @default(now())

  message       ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUser User        @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId])
  @@index([workspaceId])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id           String    @id @default(cuid())
  actorUserId  String?
  actorEmail   String?
  action       String
  entityType   String
  entityId     String?
  workspaceId  String?
  targetUserId String?
  beforeJson   Json?
  afterJson    Json?
  metadata     Json?
  createdAt    DateTime  @default(now())

  actorUser  User?      @relation("AuditLogActor",     fields: [actorUserId],  references: [id], onDelete: SetNull)
  workspace  Workspace? @relation("AuditLogWorkspace", fields: [workspaceId],  references: [id], onDelete: SetNull)
  targetUser User?      @relation("AuditLogTarget",    fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([workspaceId])
  @@index([targetUserId])
  @@index([action])
}
