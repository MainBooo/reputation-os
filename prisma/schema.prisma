generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  YANDEX
  GOOGLE
  TWOGIS
  WEB
  CUSTOM
}

enum SourceType {
  REVIEW_FEED
  RATING_FEED
  WEB_MENTION_FEED
  CUSTOM_FEED
}

enum MentionType {
  REVIEW
  ARTICLE
  WEB_MENTION
  SOCIAL_MENTION
  COMMENT
}

enum MentionStatus {
  NEW
  REVIEWED
  HIDDEN
  ARCHIVED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
  UNKNOWN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum SystemRole {
  USER
  SUPER_ADMIN
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WEBHOOK
  IN_APP
}

enum NotificationType {
  NEW_NEGATIVE_MENTION
  NEW_REVIEW
  RATING_DROP
  DAILY_DIGEST
  AI_REPLY_READY
  WORKSPACE_INVITE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  isActive     Boolean    @default(true)
  systemRole   SystemRole @default(USER)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  telegramChatId    BigInt?   @unique
  telegramLinkedAt  DateTime?
  updatedAt    DateTime   @updatedAt

  workspaceMembers     WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[]
  notifications        Notification[]
  aiReplyDrafts        AIReplyDraft[]        @relation("AIReplyDraftCreatedBy")
  jobLogsTriggered     JobLog[]              @relation("JobLogTriggeredBy")
  webPushSubscriptions WebPushSubscription[]
  telegramLinkToken    TelegramLinkToken?
  telegramDeliveries   TelegramMentionDelivery[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              WorkspaceMember[]
  invites              WorkspaceInvite[]
  companies            Company[]
  sources              Source[]
  notificationRules    NotificationRule[]
  subscription         Subscription?
  payments             Payment[]
  featureOverrides     FeatureOverride[]
  webPushSubscriptions WebPushSubscription[]

  @@index([slug])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  token       String        @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  declinedAt  DateTime?
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

model Company {
  id                     String    @id @default(cuid())
  workspaceId            String
  name                   String
  normalizedName         String
  website                String?
  normalizedWebsite      String?
  city                   String?
  normalizedCity         String?
  industry               String?
  description            String?
  logoUrl                String?
  isActive               Boolean   @default(true)
  initialSyncCompletedAt DateTime?
  lastSyncedAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aliases           CompanyAlias[]
  sourceTargets     CompanySourceTarget[]
  mentions          Mention[]
  ratingSnapshots   RatingSnapshot[]
  aiReplyDrafts     AIReplyDraft[]
  notificationRules NotificationRule[]
  subscription      Subscription?         @relation(fields: [subscriptionId], references: [id])
  payments          Payment[]
  featureOverrides  FeatureOverride[]
  jobLogs           JobLog[]
  subscriptionId    String?

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([normalizedName])
  @@index([normalizedWebsite])
  @@index([normalizedCity])
}

model CompanyAlias {
  id              String   @id @default(cuid())
  companyId       String
  value           String
  normalizedValue String
  priority        Int      @default(100)
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, normalizedValue])
  @@index([companyId, priority])
  @@index([normalizedValue])
}

model Source {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  platform    Platform
  type        SourceType
  baseUrl     String?
  isEnabled   Boolean    @default(true)
  config      Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyTargets    CompanySourceTarget[]
  mentions          Mention[]
  ratingSnapshots   RatingSnapshot[]
  jobLogs           JobLog[]
  notificationRules NotificationRule[]

  @@index([workspaceId])
  @@index([workspaceId, platform, type])
  @@index([platform, type])
}

model CompanySourceTarget {
  id                  String    @id @default(cuid())
  companyId           String
  sourceId            String
  externalPlaceId     String?
  externalUrl         String?
  displayName         String?
  isActive            Boolean   @default(true)
  syncReviewsEnabled  Boolean   @default(true)
  syncRatingsEnabled  Boolean   @default(true)
  syncMentionsEnabled Boolean   @default(true)
  config              Json?
  lastSyncedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source          Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  mentions        Mention[]
  ratingSnapshots RatingSnapshot[]

  @@unique([companyId, sourceId, externalPlaceId])
  @@index([companyId])
  @@index([sourceId])
  @@index([companyId, isActive])
  @@index([companyId, sourceId])
}

model Mention {
  id                    String      @id @default(cuid())
  companyId             String
  platform              Platform
  type                  MentionType
  sourceId              String
  companySourceTargetId String?

  externalMentionId String?
  url               String?
  title             String?
  content           String
  normalizedContent String
  author            String?
  authorExternalId  String?
  publishedAt       DateTime
  discoveredAt      DateTime      @default(now())
  ratingValue       Decimal?      @db.Decimal(3, 1)
  sentiment         Sentiment     @default(UNKNOWN)
  status            MentionStatus @default(NEW)

  isRelevant     Boolean  @default(true)
  relevanceScore Decimal? @db.Decimal(5, 2)
  hash           String
  duplicateOfId  String?

  rawPayload Json?
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source              Source               @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  companySourceTarget CompanySourceTarget? @relation(fields: [companySourceTargetId], references: [id], onDelete: SetNull)

  duplicateOf Mention?  @relation("MentionDuplicateLink", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates  Mention[] @relation("MentionDuplicateLink")

  aiReplyDrafts AIReplyDraft[]
  telegramDeliveries TelegramMentionDelivery[]

  @@unique([companyId, platform, externalMentionId], map: "mention_company_platform_external_unique")
  @@unique([companyId, hash], map: "mention_company_hash_unique")
  @@index([companyId])
  @@index([companyId, publishedAt(sort: Desc)])
  @@index([companyId, platform, publishedAt(sort: Desc)])
  @@index([companyId, type, publishedAt(sort: Desc)])
  @@index([companyId, sentiment, publishedAt(sort: Desc)])
  @@index([sourceId, publishedAt(sort: Desc)])
  @@index([companySourceTargetId])
  @@index([externalMentionId])
  @@index([hash])
  @@index([duplicateOfId])
}

model RatingSnapshot {
  id                    String   @id @default(cuid())
  companyId             String
  sourceId              String
  companySourceTargetId String?
  platform              Platform
  ratingValue           Decimal  @db.Decimal(3, 1)
  reviewsCount          Int?
  capturedAt            DateTime
  rawPayload            Json?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source              Source               @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  companySourceTarget CompanySourceTarget? @relation(fields: [companySourceTargetId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, capturedAt(sort: Desc)])
  @@index([companyId, platform, capturedAt(sort: Desc)])
  @@index([sourceId, capturedAt(sort: Desc)])
  @@index([companySourceTargetId])
}

model AIReplyDraft {
  id              String   @id @default(cuid())
  companyId       String
  mentionId       String
  createdByUserId String?
  languageCode    String   @default("ru")
  tone            String?
  promptVersion   String?
  draftText       String
  status          String   @default("READY")
  modelName       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mention       Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("AIReplyDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([mentionId])
  @@index([createdByUserId])
  @@index([companyId, createdAt(sort: Desc)])
}

model NotificationRule {
  id          String              @id @default(cuid())
  workspaceId String
  companyId   String?
  name        String
  isActive    Boolean             @default(true)
  channel     NotificationChannel
  type        NotificationType

  platformFilter    Platform?
  mentionTypeFilter MentionType?
  sentimentFilter   Sentiment?
  sourceIdFilter    String?

  minRatingValue Decimal? @db.Decimal(3, 1)
  maxRatingValue Decimal? @db.Decimal(3, 1)
  config         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceFilter Source?   @relation(fields: [sourceIdFilter], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([companyId])
  @@index([sourceIdFilter])
  @@index([workspaceId, isActive])
  @@index([workspaceId, type, channel])
}

model WebPushSubscription {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String
  endpoint    String  @unique
  p256dh      String
  auth        String
  userAgent   String?
  isActive    Boolean @default(true)

  alertSentiments    String[]  @default(["NEGATIVE"])
  lastAlertCheckedAt DateTime?
  lastUsedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, isActive])
  @@index([userId, isActive])
  @@index([workspaceId, isActive, lastAlertCheckedAt])
}

model JobLog {
  id                String    @id @default(cuid())
  companyId         String?
  sourceId          String?
  triggeredByUserId String?
  queueName         String
  jobName           String
  jobStatus         JobStatus
  startedAt         DateTime?
  finishedAt        DateTime?
  itemsDiscovered   Int?
  itemsCreated      Int?
  itemsUpdated      Int?
  itemsDeduped      Int?
  errorMessage      String?
  payload           Json?
  result            Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  source          Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  triggeredByUser User?    @relation("JobLogTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([sourceId])
  @@index([triggeredByUserId])
  @@index([jobStatus])
  @@index([queueName, jobName])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// BILLING
// ============================================

enum PlanCode {
  FREE
  START
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
}

enum BillingProvider {
  MOCK
  YOOKASSA
}

model Plan {
  id           String   @id @default(cuid())
  code         PlanCode @unique
  name         String
  priceMonthly Int // рубли в месяц
  isActive     Boolean  @default(true)
  limits       Json // { maxCompanies, maxAiRepliesPerMonth, platforms[], telegramNotifications, advancedAnalytics }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                String             @id @default(cuid())
  workspaceId       String             @unique
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  provider          BillingProvider    @default(MOCK)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])
  Company   Company[]

  @@index([status, currentPeriodEnd])
}

model Payment {
  id                String          @id @default(cuid())
  workspaceId       String
  planCode          PlanCode
  amount            Int // рубли
  currency          String          @default("RUB")
  status            PaymentStatus   @default(PENDING)
  provider          BillingProvider @default(MOCK)
  providerPaymentId String?         @unique
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@index([workspaceId])
  @@index([status])
}

model FeatureOverride {
  id          String   @id @default(cuid())
  workspaceId String
  featureKey  String // 'telegramNotifications' | 'advancedAnalytics' | 'maxCompanies' | 'maxAiRepliesPerMonth' | 'platforms'
  value       Json // true/false или число/массив для лимитов
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@unique([workspaceId, featureKey])
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TelegramDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model TelegramMentionDelivery {
  id        String                 @id @default(cuid())
  mentionId String
  userId    String
  chatId    BigInt
  status    TelegramDeliveryStatus @default(PENDING)
  attempts  Int                    @default(0)
  lastError String?
  sentAt    DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  mention Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mentionId, userId], map: "telegram_delivery_mention_user_unique")
  @@index([mentionId])
  @@index([userId])
  @@index([status])
}
